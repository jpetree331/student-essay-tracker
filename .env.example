PORT=3010
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/essay_organizer

# AI features (optional). Without a key, AI buttons return a clear error and
# the rest of the app works normally.
#
# Provider is picked automatically: Anthropic if ANTHROPIC_API_KEY is set,
# else OpenAI if OPENAI_API_KEY is set. Set AI_PROVIDER=anthropic|openai to
# force one when both keys are present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=

# Optional model overrides (defaults shown)
# ANTHROPIC_TAG_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_COMPARE_MODEL=claude-sonnet-4-6
# OPENAI_TAG_MODEL=gpt-5-mini
# OPENAI_COMPARE_MODEL=gpt-5
